# Snowflake — account identifier format: ORG-ACCOUNT (e.g. MCIBTRB-FZC69548)
SNOWFLAKE_ACCOUNT=MYORG-MYACCOUNT
SNOWFLAKE_USER=myuser
SNOWFLAKE_PASSWORD=mypassword
SNOWFLAKE_WAREHOUSE=CRYPTO_WH
SNOWFLAKE_ROLE=STREAM_ROLE

# Kafka (internal Docker network address)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=crypto_trades

# Binance symbols (comma-separated, uppercase)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
